{
  "name": "brushengine",
  "private": true,
  "version": "0.1.0",
  "description": "Hand-drawn 2-point-perspective brush renderer with a generative cityscape.",
  "type": "module",
  "main": "./dist/brushengine.cjs",
  "module": "./dist/brushengine.js",
  "types": "./dist/types/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/lib/index.d.ts",
      "import": "./dist/brushengine.js",
      "require": "./dist/brushengine.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "gen:brushes": "node scripts/gen-brush-data.mjs",
    "build:lib": "vite build --config vite.lib.config.ts && tsc -p tsconfig.lib.json",
    "perf": "node perf/run.mjs",
    "perf:compare": "node perf/compare.mjs"
  },
  "peerDependencies": {
    "three": ">=0.160.0 <1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.60.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.170.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.3"
  }
}
